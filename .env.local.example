# Algonyte env vars — copy this file to .env.local and fill in real values.
# .env.local is gitignored; .env.local.example is the committed template.

# ─── LeadConnector / GoHighLevel intake ───────────────────────────────────
# Private Integration token. Generate in GHL: Settings → Private Integrations
# → + Create. Grant scopes: contacts.write, contacts.readonly.
# Server-only — never expose to the client. Do not prefix with NEXT_PUBLIC_.
LC_API_TOKEN=

# Sub-account location ID. Find in GHL: Settings → Business Profile →
# "Location ID" field (also visible in any URL inside the sub-account).
LC_LOCATION_ID=
